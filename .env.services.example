# =============================================================================
# Omni-G Local Services Environment Variables
# =============================================================================
# Copy this file to .env.services.local to run Aggregator, Processor, and Delivery
# directly on your host machine (outside Docker).
#
# USAGE EXAMPLES:
#   cp .env.services.example .env.services.local
#   source .env.services.local
#   # then run the services in separate terminals
# =============================================================================

# Common
LOG_LEVEL=debug
HTTP_PORT=8001
TENANT_ID=dev-tenant

# Kafka
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:19092
KAFKA_GROUP_ID=processor-group
KAFKA_TOPIC=raw-feed
KAFKA_RAW_TOPIC=raw-feed
KAFKA_ENTITIES_TOPIC=processed-entities
KAFKA_ALERTS_TOPIC=analyst-alerts
KAFKA_DLQ_TOPIC=raw-feed.dlq
KAFKA_NUM_WORKERS=1

# Aggregator
VALIDATION_SERVICE_URL=http://localhost:8001
MCP_PLUGIN_URLS=http://localhost:8090
SCHEDULER_INTERVAL_MS=30000

# Processor
REDIS_URL=redis://localhost:6379
NEO4J_URL=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=omni-g-local-dev
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=omni-g-local-dev
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
LLM_TIMEOUT_SECONDS=120
OPENAI_API_KEY=
KOKORO_URL=http://localhost:8000
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=omni-g-local-dev
MINIO_BUCKET=omni-g-briefings
BRIEFING_PREFLIGHT_ENABLED=false
BRIEFING_PREFLIGHT_STRICT=false

# Delivery
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_TENANT_ID=dev-tenant
PROCESSOR_URL=http://localhost:8001
GATEWAY_PORT=3001
METRICS_PORT=9464
