# =============================================================================
# Omni-G Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit secrets.
#
# USAGE:
#   cp .env.example .env.local
#   # Edit .env.local with real values
#   docker compose --env-file .env.local --profile core up
# =============================================================================


# =============================================================================
# NEO4J
# =============================================================================
NEO4J_AUTH=neo4j/change-me-in-production
NEO4J_PASSWORD=change-me-in-production
NEO4J_USER=neo4j
NEO4J_URL=neo4j://neo4j:7687
# Memory settings (tune for your machine — default targets 8 GB total)
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=512M


# =============================================================================
# REDIS
# =============================================================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379


# =============================================================================
# QDRANT
# =============================================================================
QDRANT_API_KEY=change-me-in-production
QDRANT_URL=http://qdrant:6333


# =============================================================================
# KAFKA
# =============================================================================
KAFKA_BROKERS=kafka:9092


# =============================================================================
# OLLAMA (LLM)
# =============================================================================
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_URL=http://ollama:11434
# Comma-separated list of models to pull on startup (optional)
# OLLAMA_MODELS=qwen2.5:3b,nomic-embed-text


# =============================================================================
# KOKORO TTS
# =============================================================================
KOKORO_WORKERS=1


# =============================================================================
# MINIO (Object Storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production
MINIO_URL=http://minio:9000


# =============================================================================
# GRAFANA
# =============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-in-production


# =============================================================================
# AGGREGATOR SERVICE (Go)
# =============================================================================
AGGREGATOR_LOG_LEVEL=info
# URL to the validation sidecar (processor health endpoint)
AGGREGATOR_VALIDATION_SERVICE_URL=http://processor:8001


# =============================================================================
# PROCESSOR SERVICE (Python)
# =============================================================================
PROCESSOR_LOG_LEVEL=info
# OpenAI-compatible API key (leave blank if using Ollama only)
OPENAI_API_KEY=
# Optional: override LLM model
LLM_MODEL=qwen2.5:3b
LLM_EMBEDDING_MODEL=nomic-embed-text


# =============================================================================
# DELIVERY SERVICE (Next.js)
# =============================================================================
# Public URLs (used by the browser — must be reachable from the client)
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:3001


# =============================================================================
# MULTI-TENANCY
# =============================================================================
# Default tenant ID for single-tenant development
DEFAULT_TENANT_ID=dev-tenant


# =============================================================================
# SECURITY (Phase 6+)
# =============================================================================
# JWT signing secret — MUST be changed before any shared deployment
JWT_SECRET=change-me-in-production-use-32-char-minimum
