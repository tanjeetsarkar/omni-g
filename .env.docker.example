# =============================================================================
# Omni-G Docker Environment Variables
# =============================================================================
# Copy this file to .env.docker.local and fill in your values.
# .env.docker.local is gitignored — never commit secrets.
#
# USAGE:
#   cp .env.docker.example .env.docker.local
#   docker compose -f infrastructure/docker-compose.yml --env-file .env.docker.local --profile core up -d
# =============================================================================

# NEO4J
NEO4J_AUTH=neo4j/change-me-in-production
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-production
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=512M
NEO4J_URL=neo4j://neo4j:7687

# REDIS
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# QDRANT
QDRANT_API_KEY=change-me-in-production
QDRANT_URL=http://qdrant:6333

# KAFKA
KAFKA_BROKERS=kafka:9092
KAFKA_ALERTS_TOPIC=analyst-alerts

# OLLAMA + LLM
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_URL=http://ollama:11434
LLM_MODEL=qwen2.5:3b
OPENAI_API_KEY=

# KOKORO TTS
KOKORO_WORKERS=1
KOKORO_URL=http://kokoro-tts:8880

# MINIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production
MINIO_URL=http://minio:9000
MINIO_BUCKET=omni-g-briefings

# GRAFANA
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-in-production

# AGGREGATOR
AGGREGATOR_LOG_LEVEL=info
AGGREGATOR_VALIDATION_SERVICE_URL=http://processor:8001

# PROCESSOR
PROCESSOR_LOG_LEVEL=info
PROCESSOR_KAFKA_ENABLED=true

# DELIVERY
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
PROCESSOR_URL=http://processor:8001
GATEWAY_PORT=3001
METRICS_PORT=9464

# MULTI-TENANCY + SECURITY
DEFAULT_TENANT_ID=dev-tenant
JWT_SECRET=change-me-in-production-use-32-char-minimum
